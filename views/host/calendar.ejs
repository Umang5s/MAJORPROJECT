</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // State
        let currentDate = new Date();
        let currentMonth = currentDate.getMonth();
        let currentYear = currentDate.getFullYear();
        let selectedDate = null;
        let currentView = 'month';
        let weekStartDate = new Date(currentYear, currentMonth, 1);
        let selectedDayView = new Date(currentYear, currentMonth, 1);
        
        // Store custom status for each date
        let dateStatuses = {};
        let datePrices = {};
        let blockedDates = [];
        let priceOverrides = [];
        
        // Bookings data from server
        const bookings = <%- JSON.stringify(bookings) %>;
        
        // Get listings data
        const listings = <%- JSON.stringify(listings) %>;
        
        // Listing colors
        const listingColors = {};
        const colorPalette = ['#FF385C', '#00A699', '#FC642D', '#484848', '#008489', '#FFB400'];
        
        if (listings && listings.length > 0) {
            listings.forEach((listing, index) => {
                const colorIndex = index % colorPalette.length;
                listingColors[listing._id] = colorPalette[colorIndex];
            });
        }
        
        // Current listing ID
        let currentListingId = 'all';
        
        // DOM Elements
        const calendarGrid = document.getElementById('calendarGrid');
        const monthTitle = document.getElementById('monthTitle');
        const todayBtn = document.getElementById('todayBtn');
        const prevBtn = document.getElementById('prevMonth');
        const nextBtn = document.getElementById('nextMonth');
        const navButtons = document.getElementById('navButtons');
        const listingFilter = document.getElementById('listingFilter');
        const viewToggle = document.querySelectorAll('.toggle-btn');
        const popup = document.getElementById('datePopup');
        const closePopup = document.getElementById('closePopup');
        const cancelPopup = document.getElementById('cancelPopup');
        const savePopup = document.getElementById('savePopup');
        const popupDate = document.getElementById('popupDate');
        const popupStatus = document.getElementById('popupStatus');
        const originalPrice = document.getElementById('originalPrice');
        const lastMinutePrice = document.getElementById('lastMinutePrice');
        const blockDate = document.getElementById('blockDate');
        const customSettings = document.getElementById('customSettings');
        const bookingDetails = document.getElementById('bookingDetails');
        const lastMinuteOption = document.getElementById('lastMinuteOption');
        const blockOption = document.getElementById('blockOption');
        const loadingOverlay = document.getElementById('loadingOverlay');
        const toastContainer = document.getElementById('toastContainer');
        const refreshBtn = document.getElementById('refreshStats');
        const monthDropdownBtn = document.getElementById('monthDropdownBtn');
        const monthDropdown = document.getElementById('monthDropdown');
        const prevYear = document.getElementById('prevYear');
        const nextYear = document.getElementById('nextYear');
        const currentYearSpan = document.getElementById('currentYear');
        const monthGrid = document.getElementById('monthGrid');
        const pricePresets = document.querySelectorAll('.preset-btn');
        const tabBtns = document.querySelectorAll('.tab-btn');
        
        // Stats elements
        const bookedNightsEl = document.getElementById('bookedNights');
        const availableNightsEl = document.getElementById('availableNights');
        const blockedNightsEl = document.getElementById('blockedNights');
        const estimatedEarningsEl = document.getElementById('estimatedEarnings');
        const occupancyPercent = document.getElementById('occupancyPercent');
        const occupancyBar = document.getElementById('occupancyBar');
        const availableCount = document.getElementById('availableCount');
        const bookedCount = document.getElementById('bookedCount');
        const blockedCount = document.getElementById('blockedCount');
        const todayBookingsEl = document.getElementById('todayBookings');
        const upcomingBookingsEl = document.getElementById('upcomingBookings');
        const recentBookingsEl = document.getElementById('recentBookings');
        
        // Booking detail elements
        const bookingGuest = document.getElementById('bookingGuest');
        const bookingCheckIn = document.getElementById('bookingCheckIn');
        const bookingCheckOut = document.getElementById('bookingCheckOut');
        const bookingListing = document.getElementById('bookingListing');

        // ============== UTILITY FUNCTIONS ==============

        function showLoading() {
            loadingOverlay.classList.add('show');
        }

        function hideLoading() {
            loadingOverlay.classList.remove('show');
        }

        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <i class="fa-regular fa-circle-check"></i>
                <span>${message}</span>
            `;
            toastContainer.appendChild(toast);
            
            setTimeout(() => toast.classList.add('show'), 100);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function formatNumber(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        function formatDate(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function formatPrice(price) {
            if (price >= 1000) {
                return '₹' + (price / 1000).toFixed(1) + 'K';
            }
            return '₹' + price;
        }

        // ============== API FUNCTIONS ==============

        async function fetchBlockedDates(listingId, year, month) {
            if (listingId === 'all') {
                blockedDates = [];
                return;
            }
            
            try {
                const response = await fetch(`/host/calendar/blocked-dates?listingId=${listingId}&year=${year}&month=${month + 1}`);
                const data = await response.json();
                blockedDates = data.blockedDates || [];
                
                Object.keys(dateStatuses).forEach(key => {
                    if (dateStatuses[key] === 'blocked') delete dateStatuses[key];
                });
                
                blockedDates.forEach(dateStr => dateStatuses[dateStr] = 'blocked');
            } catch (error) {
                console.error('Error:', error);
            }
        }

        async function fetchPriceOverrides(listingId, year, month) {
            if (listingId === 'all') {
                priceOverrides = [];
                return;
            }
            
            try {
                const response = await fetch(`/host/calendar/price-overrides?listingId=${listingId}&year=${year}&month=${month + 1}`);
                const data = await response.json();
                priceOverrides = data.priceOverrides || [];
                datePrices = {};
                priceOverrides.forEach(override => datePrices[override.date] = override.price);
            } catch (error) {
                console.error('Error:', error);
            }
        }

        async function saveBlockedDate(listingId, dateStr, isBlocked) {
            try {
                const response = await fetch('/host/calendar/block-date', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ listingId, date: dateStr, blocked: isBlocked })
                });
                const data = await response.json();
                return data.success;
            } catch (error) {
                console.error('Error:', error);
                return false;
            }
        }

        async function savePriceOverride(listingId, dateStr, price) {
            try {
                const response = await fetch('/host/calendar/update-price', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ listingId, date: dateStr, price })
                });
                const data = await response.json();
                return data.success;
            } catch (error) {
                console.error('Error:', error);
                return false;
            }
        }

        // ============== CALENDAR FUNCTIONS ==============

        function getBookingsForDate(date) {
            return bookings.filter(booking => {
                const checkIn = new Date(booking.checkIn);
                const checkOut = new Date(booking.checkOut);
                checkIn.setHours(0,0,0,0);
                checkOut.setHours(0,0,0,0);
                const compareDate = new Date(date);
                compareDate.setHours(0,0,0,0);
                return compareDate >= checkIn && compareDate < checkOut;
            });
        }

        function getDateStatus(date, dateStr) {
            if (dateStatuses.hasOwnProperty(dateStr)) return 'blocked';
            if (getBookingsForDate(date).length > 0) return 'booked';
            return 'available';
        }

        function getDatePrice(date, dateStr) {
            if (datePrices.hasOwnProperty(dateStr)) return datePrices[dateStr];
            
            const defaultPrice = 2289;
            const dayOfWeek = date.getDay();
            if (dayOfWeek === 5 || dayOfWeek === 6) {
                return Math.round(defaultPrice * 1.1);
            }
            return defaultPrice;
        }

        function updateStats() {
            const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
            let booked = 0, available = 0, blocked = 0, totalEarnings = 0;
            
            for (let day = 1; day <= daysInMonth; day++) {
                const date = new Date(currentYear, currentMonth, day);
                const dateStr = formatDate(date);
                const status = getDateStatus(date, dateStr);
                const price = getDatePrice(date, dateStr);
                
                switch(status) {
                    case 'booked': booked++; totalEarnings += price; break;
                    case 'available': available++; break;
                    case 'blocked': blocked++; break;
                }
            }
            
            bookedNightsEl.textContent = booked;
            availableNightsEl.textContent = available;
            blockedNightsEl.textContent = blocked;
            estimatedEarningsEl.textContent = '₹' + formatNumber(totalEarnings);
            
            const totalNights = booked + available + blocked;
            const occupancyRate = totalNights > 0 ? Math.round((booked / totalNights) * 100) : 0;
            occupancyPercent.textContent = occupancyRate + '%';
            occupancyBar.style.width = occupancyRate + '%';
            
            availableCount.textContent = available;
            bookedCount.textContent = booked;
            blockedCount.textContent = blocked;
        }

        function updateBookingsTabs() {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            
            const todaysBookings = bookings.filter(booking => {
                const checkIn = new Date(booking.checkIn);
                checkIn.setHours(0, 0, 0, 0);
                return checkIn.getTime() === today.getTime();
            });
            
            const upcoming = bookings
                .filter(booking => new Date(booking.checkIn) > today)
                .sort((a, b) => new Date(a.checkIn) - new Date(b.checkIn))
                .slice(0, 5);
            
            const recent = [...bookings]
                .sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt))
                .slice(0, 5);
            
            renderBookingsTab(todayBookingsEl, todaysBookings, 'No check-ins today');
            renderBookingsTab(upcomingBookingsEl, upcoming, 'No upcoming bookings');
            renderBookingsTab(recentBookingsEl, recent, 'No recent bookings');
        }

        function renderBookingsTab(container, bookingsList, emptyMessage) {
            if (bookingsList.length === 0) {
                container.innerHTML = `<p class="no-bookings">${emptyMessage}</p>`;
                return;
            }
            
            let html = '';
            bookingsList.forEach(booking => {
                const guestName = booking.guest?.username || booking.guestDetails?.name || 'Guest';
                const checkIn = new Date(booking.checkIn).toLocaleDateString();
                const checkOut = new Date(booking.checkOut).toLocaleDateString();
                const listingId = booking.listing?._id || booking.listing;
                const color = listingColors[listingId] || '#FF385C';
                
                html += `
                    <div class="booking-item" style="border-left-color: ${color}" data-booking-id="${booking._id}">
                        <div class="booking-guest">${guestName}</div>
                        <div class="booking-dates">${checkIn} → ${checkOut}</div>
                    </div>
                `;
            });
            
            container.innerHTML = html;
            
            container.querySelectorAll('.booking-item').forEach(item => {
                item.addEventListener('click', () => {
                    const bookingId = item.dataset.bookingId;
                    window.location.href = `/bookings/${bookingId}`;
                });
            });
        }

        function renderMonthGrid() {
            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            let html = '';
            
            months.forEach((month, index) => {
                const isCurrent = index === currentMonth;
                html += `<button class="${isCurrent ? 'active' : ''}" data-month="${index}">${month}</button>`;
            });
            
            monthGrid.innerHTML = html;
            
            monthGrid.querySelectorAll('button').forEach(btn => {
                btn.addEventListener('click', () => {
                    currentMonth = parseInt(btn.dataset.month);
                    renderCalendar();
                    monthDropdown.classList.remove('show');
                });
            });
        }

        // ============== VIEW RENDERERS ==============

        function renderCalendar() {
            if (currentView === 'month') renderMonthView();
            else if (currentView === 'week') renderWeekView();
            else renderDayView();
        }

        function renderMonthView() {
            const firstDay = new Date(currentYear, currentMonth, 1);
            const startDay = firstDay.getDay();
            const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
            const today = new Date();
            
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                'July', 'August', 'September', 'October', 'November', 'December'];
            monthTitle.textContent = `${monthNames[currentMonth]} ${currentYear}`;
            
            let html = '';
            
            for (let i = 0; i < startDay; i++) {
                html += '<div class="date-cell empty"></div>';
            }
            
            for (let day = 1; day <= daysInMonth; day++) {
                const date = new Date(currentYear, currentMonth, day);
                const dateStr = formatDate(date);
                const isToday = date.toDateString() === today.toDateString();
                const status = getDateStatus(date, dateStr);
                const price = getDatePrice(date, dateStr);
                const formattedPrice = formatPrice(price);
                const bookingsForDate = getBookingsForDate(date);
                const isSelected = selectedDate && selectedDate.toDateString() === date.toDateString();
                
                let cellClasses = `date-cell ${status}`;
                if (isSelected) cellClasses += ' selected';
                if (isToday) cellClasses += ' today';
                
                html += `
                    <div class="${cellClasses}" data-date="${dateStr}">
                        <span class="date-number">${day}</span>
                        <span class="price">${formattedPrice}</span>
                    </div>
                `;
            }
            
            calendarGrid.innerHTML = html;
            updateStats();
            updateBookingsTabs();
        }

        function renderWeekView() {
            const weekStart = new Date(weekStartDate);
            weekStart.setHours(0, 0, 0, 0);
            
            while (weekStart.getDay() !== 0) {
                weekStart.setDate(weekStart.getDate() - 1);
            }
            
            const weekEnd = new Date(weekStart);
            weekEnd.setDate(weekEnd.getDate() + 6);
            
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                'July', 'August', 'September', 'October', 'November', 'December'];
            
            const startFormatted = `${monthNames[weekStart.getMonth()]} ${weekStart.getDate()}`;
            const endFormatted = `${monthNames[weekEnd.getMonth()]} ${weekEnd.getDate()}, ${weekEnd.getFullYear()}`;
            monthTitle.textContent = `${startFormatted} - ${endFormatted}`;
            
            let html = '';
            
            for (let i = 0; i < 7; i++) {
                const date = new Date(weekStart);
                date.setDate(weekStart.getDate() + i);
                const dateStr = formatDate(date);
                const isToday = date.toDateString() === new Date().toDateString();
                const status = getDateStatus(date, dateStr);
                const price = getDatePrice(date, dateStr);
                const formattedPrice = formatPrice(price);
                const bookingsForDate = getBookingsForDate(date);
                const isSelected = selectedDate && selectedDate.toDateString() === date.toDateString();
                
                let cellClasses = `date-cell week-view-cell ${status}`;
                if (isSelected) cellClasses += ' selected';
                if (isToday) cellClasses += ' today';
                
                const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
                
                html += `
                    <div class="${cellClasses}" data-date="${dateStr}">
                        <span class="date-number">${dayNames[date.getDay()]} ${date.getDate()}</span>
                        <span class="price">${formattedPrice}</span>
                    </div>
                `;
            }
            
            calendarGrid.innerHTML = html;
            updateStats();
        }

        function renderDayView() {
            const date = new Date(selectedDayView);
            date.setHours(0, 0, 0, 0);
            const dateStr = formatDate(date);
            
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                'July', 'August', 'September', 'October', 'November', 'December'];
            const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            
            monthTitle.textContent = `${dayNames[date.getDay()]}, ${monthNames[date.getMonth()]} ${date.getDate()}, ${date.getFullYear()}`;
            
            const isToday = date.toDateString() === new Date().toDateString();
            const status = getDateStatus(date, dateStr);
            const price = getDatePrice(date, dateStr);
            const formattedPrice = formatPrice(price);
            const bookingsForDate = getBookingsForDate(date);
            
            let bookingDetails = '';
            if (bookingsForDate.length > 0) {
                bookingDetails = '<div class="day-view-bookings-container">';
                bookingsForDate.forEach(booking => {
                    const guestName = booking.guest?.username || booking.guestDetails?.name || 'Guest';
                    const checkIn = new Date(booking.checkIn).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    const checkOut = new Date(booking.checkOut).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    
                    bookingDetails += `
                        <div class="day-view-booking" data-booking-id="${booking._id}">
                            <div class="booking-time">${checkIn} - ${checkOut}</div>
                            <div class="booking-guest">${guestName}</div>
                        </div>
                    `;
                });
                bookingDetails += '</div>';
            } else {
                bookingDetails = '<div class="no-bookings">No bookings for this day</div>';
            }
            
            calendarGrid.innerHTML = `
                <div class="day-view-container">
                    <div class="day-view-cell ${status}">
                        <span class="date-number">${date.getDate()}</span>
                        <span class="price">${formattedPrice}</span>
                        <span class="status-badge ${status}">${status}</span>
                    </div>
                    ${bookingDetails}
                </div>
            `;
        }

        // ============== EVENT HANDLERS ==============

        calendarGrid.addEventListener('click', (e) => {
            const cell = e.target.closest('.date-cell');
            if (!cell || cell.classList.contains('empty')) return;
            
            const dateStr = cell.dataset.date;
            selectedDate = new Date(dateStr + 'T00:00:00');
            
            document.querySelectorAll('.date-cell').forEach(c => c.classList.remove('selected'));
            cell.classList.add('selected');
            
            const status = getDateStatus(selectedDate, dateStr);
            const price = getDatePrice(selectedDate, dateStr);
            const bookingsForDate = getBookingsForDate(selectedDate);
            
            popupDate.textContent = selectedDate.toLocaleDateString('en-US', { 
                month: 'short', day: 'numeric', year: 'numeric' 
            });
            
            popupStatus.textContent = status.charAt(0).toUpperCase() + status.slice(1);
            popupStatus.className = 'date-status ' + status;
            
            if (bookingsForDate.length > 0) {
                const booking = bookingsForDate[0];
                bookingDetails.style.display = 'block';
                bookingGuest.textContent = booking.guest?.username || booking.guestDetails?.name || 'Guest';
                bookingCheckIn.textContent = new Date(booking.checkIn).toLocaleDateString();
                bookingCheckOut.textContent = new Date(booking.checkOut).toLocaleDateString();
                bookingListing.textContent = booking.listing?.title || 'Listing';
                
                lastMinuteOption.classList.add('disabled');
                blockOption.classList.add('disabled');
            } else {
                bookingDetails.style.display = 'none';
                lastMinuteOption.classList.remove('disabled');
                blockOption.classList.remove('disabled');
            }
            
            originalPrice.textContent = '₹' + formatNumber(price);
            lastMinutePrice.value = Math.round(price * 0.95);
            blockDate.checked = status === 'blocked';
            
            popup.classList.add('show');
        });

        // Today button
        todayBtn.addEventListener('click', () => {
            const today = new Date();
            currentMonth = today.getMonth();
            currentYear = today.getFullYear();
            weekStartDate = new Date(today);
            selectedDayView = new Date(today);
            
            if (currentView === 'month') renderMonthView();
            else if (currentView === 'week') renderWeekView();
            else renderDayView();
            
            showToast('Jumped to today', 'info');
        });

        // Navigation
        prevBtn.addEventListener('click', async () => {
            showLoading();
            if (currentView === 'month') {
                if (currentMonth === 0) {
                    currentMonth = 11;
                    currentYear--;
                } else {
                    currentMonth--;
                }
            } else if (currentView === 'week') {
                weekStartDate.setDate(weekStartDate.getDate() - 7);
            } else {
                selectedDayView.setDate(selectedDayView.getDate() - 1);
            }
            
            if (currentListingId !== 'all') {
                await fetchBlockedDates(currentListingId, currentYear, currentMonth);
                await fetchPriceOverrides(currentListingId, currentYear, currentMonth);
            }
            
            renderCalendar();
            hideLoading();
        });

        nextBtn.addEventListener('click', async () => {
            showLoading();
            if (currentView === 'month') {
                if (currentMonth === 11) {
                    currentMonth = 0;
                    currentYear++;
                } else {
                    currentMonth++;
                }
            } else if (currentView === 'week') {
                weekStartDate.setDate(weekStartDate.getDate() + 7);
            } else {
                selectedDayView.setDate(selectedDayView.getDate() + 1);
            }
            
            if (currentListingId !== 'all') {
                await fetchBlockedDates(currentListingId, currentYear, currentMonth);
                await fetchPriceOverrides(currentListingId, currentYear, currentMonth);
            }
            
            renderCalendar();
            hideLoading();
        });

        // View toggle
        viewToggle.forEach(btn => {
            btn.addEventListener('click', function() {
                viewToggle.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                currentView = this.dataset.view;
                
                // Update navigation buttons
                if (currentView === 'month') {
                    navButtons.innerHTML = `
                        <button class="nav-btn" id="todayBtn" title="Go to today">
                            <i class="fa-regular fa-calendar-check"></i>
                            <span>Today</span>
                        </button>
                        <button class="nav-btn" id="prevMonth" title="Previous month">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <button class="nav-btn" id="nextMonth" title="Next month">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                    `;
                } else if (currentView === 'week') {
                    navButtons.innerHTML = `
                        <button class="nav-btn" id="todayBtn" title="Go to today">
                            <i class="fa-regular fa-calendar-check"></i>
                            <span>Today</span>
                        </button>
                        <button class="nav-btn" id="prevMonth" title="Previous week">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <button class="nav-btn" id="nextMonth" title="Next week">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                    `;
                } else {
                    navButtons.innerHTML = `
                        <button class="nav-btn" id="todayBtn" title="Go to today">
                            <i class="fa-regular fa-calendar-check"></i>
                            <span>Today</span>
                        </button>
                        <button class="nav-btn" id="prevMonth" title="Previous day">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <button class="nav-btn" id="nextMonth" title="Next day">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                    `;
                }
                
                // Re-attach event listeners
                document.getElementById('todayBtn').addEventListener('click', todayBtn.click);
                document.getElementById('prevMonth').addEventListener('click', prevBtn.click);
                document.getElementById('nextMonth').addEventListener('click', nextBtn.click);
                
                renderCalendar();
                showToast(`Switched to ${currentView} view`, 'info');
            });
        });

        // Popup handlers
        closePopup.addEventListener('click', () => popup.classList.remove('show'));
        cancelPopup.addEventListener('click', () => popup.classList.remove('show'));

        savePopup.addEventListener('click', async () => {
            if (!selectedDate) return;
            
            const dateStr = formatDate(selectedDate);
            const newPrice = parseInt(lastMinutePrice.value);
            const isBlocked = blockDate.checked;
            
            if (currentListingId === 'all') {
                showToast('Please select a specific listing', 'error');
                return;
            }
            
            showLoading();
            
            let success = true;
            const currentPrice = getDatePrice(selectedDate, dateStr);
            
            if (newPrice && !isNaN(newPrice) && newPrice !== currentPrice) {
                success = await savePriceOverride(currentListingId, dateStr, newPrice);
            }
            
            if (success) {
                success = await saveBlockedDate(currentListingId, dateStr, isBlocked);
            }
            
            hideLoading();
            
            if (success) {
                popup.classList.remove('show');
                await fetchBlockedDates(currentListingId, currentYear, currentMonth);
                await fetchPriceOverrides(currentListingId, currentYear, currentMonth);
                renderCalendar();
                showToast('Changes saved!', 'success');
            } else {
                showToast('Failed to save changes', 'error');
            }
        });

        popup.addEventListener('click', (e) => {
            if (e.target === popup) popup.classList.remove('show');
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && popup.classList.contains('show')) {
                popup.classList.remove('show');
            }
        });

        // Custom settings
        customSettings.addEventListener('click', (e) => {
            e.preventDefault();
            showToast('Advanced settings coming soon!', 'info');
        });

        // Refresh
        refreshBtn.addEventListener('click', async () => {
            showLoading();
            await fetchBlockedDates(currentListingId, currentYear, currentMonth);
            await fetchPriceOverrides(currentListingId, currentYear, currentMonth);
            renderCalendar();
            hideLoading();
            showToast('Calendar refreshed!', 'success');
        });

        // Filter by listing
        listingFilter.addEventListener('change', async (e) => {
            currentListingId = e.target.value;
            showLoading();
            
            dateStatuses = {};
            datePrices = {};
            
            if (currentListingId !== 'all') {
                await fetchBlockedDates(currentListingId, currentYear, currentMonth);
                await fetchPriceOverrides(currentListingId, currentYear, currentMonth);
            }
            
            renderCalendar();
            hideLoading();
            showToast(`Switched to ${e.target.options[e.target.selectedIndex].text}`, 'info');
        });

        // Month dropdown
        monthDropdownBtn.addEventListener('click', () => {
            monthDropdown.classList.toggle('show');
            currentYearSpan.textContent = currentYear;
        });

        document.addEventListener('click', (e) => {
            if (!monthDropdownBtn.contains(e.target) && !monthDropdown.contains(e.target)) {
                monthDropdown.classList.remove('show');
            }
        });

        prevYear.addEventListener('click', () => {
            currentYear--;
            currentYearSpan.textContent = currentYear;
        });

        nextYear.addEventListener('click', () => {
            currentYear++;
            currentYearSpan.textContent = currentYear;
        });

        // Quick jump
        document.querySelectorAll('.quick-jump-buttons button').forEach(btn => {
            btn.addEventListener('click', () => {
                const months = parseInt(btn.dataset.months);
                currentMonth += months;
                while (currentMonth > 11) {
                    currentMonth -= 12;
                    currentYear++;
                }
                renderCalendar();
                monthDropdown.classList.remove('show');
                showToast(`Jumped ${months} month${months > 1 ? 's' : ''} ahead`, 'info');
            });
        });

        // Price presets
        pricePresets.forEach(btn => {
            btn.addEventListener('click', () => {
                lastMinutePrice.value = btn.dataset.price;
            });
        });

        // Tab switching
        tabBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                tabBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                
                const tab = btn.dataset.tab;
                document.querySelectorAll('.tab-content').forEach(content => {
                    content.classList.remove('active');
                });
                document.getElementById(tab === 'today' ? 'todayBookings' : 
                                      tab === 'upcoming' ? 'upcomingBookings' : 'recentBookings')
                    .classList.add('active');
            });
        });

        // Initialize
        async function initialize() {
            showLoading();
            currentListingId = listingFilter.value;
            await fetchBlockedDates(currentListingId, currentYear, currentMonth);
            await fetchPriceOverrides(currentListingId, currentYear, currentMonth);
            renderMonthGrid();
            renderCalendar();
            hideLoading();
        }

        initialize();
    });
</script>