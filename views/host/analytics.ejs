<% locals.currentPath = '/host/analytics' ; %>

<!-- Include the host navbar -->
<%- include('../includes/navbar_host') %>

<div class="analytics-container">
  <!-- Header -->
  <div class="analytics-header">
    <div>
      <h1>Analytics: <%= listing.title %></h1>
      <p class="header-subtitle">Track your listing's performance</p>
    </div>
    <div class="header-actions">
      <a href="/listings/<%= listing._id %>/edit" class="btn-outline">
        <i class="fa-regular fa-pencil"></i> Edit Listing
      </a>
      <a href="/listings/<%= listing._id %>/export" class="btn-primary">
        <i class="fa-regular fa-download"></i> Export Data
      </a>
    </div>
  </div>

  <!-- Key Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-icon">
        <i class="fa-regular fa-users"></i>
      </div>
      <div class="metric-content">
        <span class="metric-label">Unique Viewers</span>
        <span class="metric-value"><%= analytics.totalUniqueViews %></span>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-icon">
        <i class="fa-regular fa-calendar"></i>
      </div>
      <div class="metric-content">
        <span class="metric-label">Avg Daily Views</span>
        <span class="metric-value"><%= analytics.avgDailyViews %></span>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-icon">
        <i class="fa-regular fa-clock"></i>
      </div>
      <div class="metric-content">
        <span class="metric-label">Last Viewed</span>
        <span class="metric-value">
          <%= analytics.lastViewed ? new Date(analytics.lastViewed).toLocaleDateString('en-US', { 
            month: 'short', 
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
          }) : 'Never' %>
        </span>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-icon">
        <i class="fa-regular fa-chart-line"></i>
      </div>
      <div class="metric-content">
        <span class="metric-label">Trend</span>
        <span class="metric-value" style="color: <%= analytics.performanceColor %>; text-transform: capitalize;">
          <%= analytics.viewTrend %>
        </span>
      </div>
    </div>
  </div>

  <!-- Views Chart -->
  <div class="chart-card">
    <div class="chart-header">
      <h2>Views (Last 30 Days)</h2>
      <div class="chart-legend">
        <span class="legend-dot" style="background: #ff385c;"></span>
        <span>Daily Unique Views</span>
      </div>
    </div>
    <div class="chart-container">
      <canvas id="viewsChart"></canvas>
    </div>
  </div>

  <!-- Performance Comparison -->
  <div class="comparison-grid">
    <!-- Performance Rating -->
    <div class="performance-card">
      <h2>Performance Rating</h2>
      <div class="performance-meter">
        <div class="meter-label" style="color: <%= analytics.performanceColor %>;">
          <%= analytics.performanceRating %>
        </div>
        <div class="meter-bar">
          <div class="meter-fill" style="width: <%= Math.min(100, (analytics.totalUniqueViews / (analytics.avgSimilarViews || 1)) * 50) %>%; background: <%= analytics.performanceColor %>;"></div>
        </div>
        <div class="meter-stats">
          <span>Your views: <%= analytics.totalUniqueViews %></span>
          <span>Avg similar: <%= analytics.avgSimilarViews %></span>
        </div>
      </div>
    </div>

    <!-- Similar Listings Comparison -->
    <div class="similar-card">
      <h2>Similar Listings</h2>
      <% if (analytics.similarListings && analytics.similarListings.length > 0) { %>
        <div class="similar-list">
          <% analytics.similarListings.forEach(similar => { %>
            <div class="similar-item">
              <span class="similar-title"><%= similar.title %></span>
              <span class="similar-views"><%= similar.views %> views</span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="no-data">No similar listings found</p>
      <% } %>
    </div>
  </div>
</div>

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Create views chart
  const ctx = document.getElementById('viewsChart').getContext('2d');
  
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: <%= JSON.stringify(analytics.chartLabels) %>,
      datasets: [{
        label: 'Daily Views',
        data: <%= JSON.stringify(analytics.chartData) %>,
        borderColor: '#ff385c',
        backgroundColor: 'rgba(255, 56, 92, 0.1)',
        borderWidth: 2,
        pointBackgroundColor: '#ff385c',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointRadius: 4,
        pointHoverRadius: 6,
        tension: 0.3,
        fill: true
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          backgroundColor: '#222',
          titleColor: '#fff',
          bodyColor: '#fff',
          padding: 12,
          cornerRadius: 8
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: {
            color: '#ebebeb'
          },
          ticks: {
            stepSize: 1
          }
        },
        x: {
          grid: {
            display: false
          }
        }
      }
    }
  });
});
</script>

<style>
.analytics-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px 24px;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

/* Header */
.analytics-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 40px;
  padding-bottom: 24px;
  border-bottom: 1px solid #ebebeb;
}

.analytics-header h1 {
  font-size: 32px;
  font-weight: 600;
  color: #222;
  margin: 0 0 8px 0;
}

.header-subtitle {
  font-size: 16px;
  color: #717171;
  margin: 0;
}

.header-actions {
  display: flex;
  gap: 12px;
}

.btn-outline, .btn-primary {
  padding: 12px 20px;
  border-radius: 30px;
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all 0.2s ease;
}

.btn-outline {
  border: 1px solid #ddd;
  color: #222;
  background: white;
}

.btn-outline:hover {
  background: #f7f7f7;
  border-color: #ccc;
}

.btn-primary {
  background: #ff385c;
  color: white;
  border: none;
}

.btn-primary:hover {
  background: #e31c5f;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(255, 56, 92, 0.2);
}

/* Metrics Grid */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 30px;
}

.metric-card {
  background: white;
  border: 1px solid #ebebeb;
  border-radius: 16px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  transition: all 0.2s ease;
}

.metric-card:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
}

.metric-icon {
  width: 48px;
  height: 48px;
  background: #fff0f2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: #ff385c;
}

.metric-content {
  flex: 1;
}

.metric-label {
  display: block;
  font-size: 13px;
  color: #717171;
  margin-bottom: 4px;
}

.metric-value {
  display: block;
  font-size: 24px;
  font-weight: 600;
  color: #222;
}

/* Chart Card */
.chart-card {
  background: white;
  border: 1px solid #ebebeb;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 30px;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.chart-header h2 {
  font-size: 18px;
  font-weight: 600;
  color: #222;
  margin: 0;
}

.chart-legend {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: #717171;
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}

.chart-container {
  height: 300px;
  position: relative;
}

/* Comparison Grid */
.comparison-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.performance-card, .similar-card {
  background: white;
  border: 1px solid #ebebeb;
  border-radius: 16px;
  padding: 24px;
}

.performance-card h2, .similar-card h2 {
  font-size: 18px;
  font-weight: 600;
  color: #222;
  margin: 0 0 20px 0;
}

/* Performance Meter */
.performance-meter {
  padding: 10px 0;
}

.meter-label {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 12px;
  text-transform: capitalize;
}

.meter-bar {
  height: 8px;
  background: #ebebeb;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 8px;
}

.meter-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.3s ease;
}

.meter-stats {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #717171;
}

/* Similar Listings */
.similar-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.similar-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #ebebeb;
}

.similar-item:last-child {
  border-bottom: none;
}

.similar-title {
  font-size: 14px;
  color: #222;
}

.similar-views {
  font-size: 14px;
  font-weight: 600;
  color: #ff385c;
}

.no-data {
  text-align: center;
  color: #717171;
  padding: 20px;
  background: #f7f7f7;
  border-radius: 8px;
}

/* Responsive */
@media (max-width: 900px) {
  .metrics-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .comparison-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .analytics-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }
  
  .header-actions {
    width: 100%;
    flex-direction: column;
  }
  
  .btn-outline, .btn-primary {
    width: 100%;
    justify-content: center;
  }
}

@media (max-width: 480px) {
  .metrics-grid {
    grid-template-columns: 1fr;
  }
  
  .analytics-header h1 {
    font-size: 24px;
  }
}
</style>