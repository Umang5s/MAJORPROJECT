<% locals.currentPath='/host/listings' ; %>

  <!-- Include the host navbar -->
  <%- include('../includes/navbar_host') %>

    <div class="host-listings-container">
      <div class="host-listings-header">
        <div>
          <h1>Your Listings</h1>
          <p class="header-subtitle">Manage and track your properties</p>
        </div>
        <button class="create-listing-btn" id="openListingModalBtn">
          <i class="fa-solid fa-plus"></i>
          Create new listing
        </button>
      </div>

      <% if (listings.length===0) { %>
        <!-- Empty state for listings -->
        <div class="empty-state">
          <div class="empty-state-icon">
            <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation"
              focusable="false"
              style="display: block; fill: none; height: 48px; width: 48px; stroke: currentcolor; stroke-width: 2; overflow: visible;">
              <g fill="none" fill-rule="evenodd">
                <path d="m2 16h28v12c0 1.1045695-.8954305 2-2 2h-24c-1.1045695 0-2-.8954305-2-2z" stroke="#222"></path>
                <path d="m2 10 14-8 14 8v6h-28z" stroke="#222"></path>
              </g>
            </svg>
          </div>
          <h2 class="empty-state-title">You don't have<br>any listings yet</h2>
          <p class="empty-state-text">Start hosting by creating your first listing</p>
          <button class="complete-listing-btn" id="openListingModalBtnEmpty">
            <i class="fa-solid fa-plus"></i>
            Create your first listing
          </button>
        </div>
        <% } else { %>
          <div class="listings-grid">
            <% listings.forEach(listing=> { %>
              <div class="listing-card">
                <div class="listing-image">
                  <!-- Use the cover image virtual -->
                  <img src="<%= listing.coverImage %>" alt="<%= listing.title %>">

                  <!-- Photo count badge -->
                  <% if (listing.photoCount> 1) { %>
                    <div class="photo-count-badge">
                      <i class="fa-regular fa-images"></i>
                      <%= listing.photoCount %>
                    </div>
                    <% } %>

                      <div class="listing-status <%= listing.isPublished ? 'published' : 'draft' %>">
                        <%= listing.isPublished ? 'Published' : 'Draft' %>
                      </div>
                </div>

                <div class="listing-info">
                  <h3>
                    <%= listing.title || 'Untitled' %>
                  </h3>

                  <p class="listing-location">
                    <i class="fa-regular fa-location-dot"></i>
                    <%= listing.location || 'Location not set' %>
                  </p>

                  <div class="listing-stats">
                    <div class="stat-item" title="Rating">
                      <i class="fa-regular fa-star"></i>
                      <span class="stat-value">
                        <%= listing.avgRating ? listing.avgRating.toFixed(1) : 'New' %>
                      </span>
                    </div>

                    <div class="stat-item" title="Unique viewers (counted once per user)">
                      <i class="fa-regular fa-users"></i>
                      <span class="stat-value">
                        <%= listing.uniqueViewers?.length || 0 %>
                      </span>
                    </div>

                    <div class="stat-item" title="Photos">
                      <i class="fa-regular fa-image"></i>
                      <span class="stat-value">
                        <%= listing.photoCount %>
                      </span>
                    </div>
                  </div>

                  <!-- Last viewed - updates on EVERY view -->
                  <% if (listing.lastViewedAt) { %>
                    <div class="last-viewed">
                      <i class="fa-regular fa-clock"></i>
                      <span>Last viewed: <%= new Date(listing.lastViewedAt).toLocaleString() %></span>
                    </div>
                    <% } else { %>
                      <div class="last-viewed never">
                        <i class="fa-regular fa-clock"></i>
                        <span>Never viewed</span>
                      </div>
                      <% } %>

                        <div class="listing-price">
                          ₹<%= listing.price?.toLocaleString('en-IN') || 0 %> <span>/ night</span>
                        </div>

                        <div class="listing-actions">
                          <a href="/listings/<%= listing._id %>" class="action-btn preview-btn" target="_blank">
                            <i class="fa-regular fa-eye"></i> Preview
                          </a>
                          <a href="/listings/<%= listing._id %>/edit" class="action-btn edit-btn">
                            <i class="fa-regular fa-pencil"></i> Edit
                          </a>
                          <a href="/listings/<%= listing._id %>/analytics" class="action-btn analytics-btn">
                            <i class="fa-regular fa-chart-bar"></i> Analytics
                          </a>
                          <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="delete-form"
                            onsubmit="return confirm('Are you sure you want to delete this listing? This action cannot be undone.');">
                            <button type="submit" class="action-btn delete-btn">
                              <i class="fa-regular fa-trash-can"></i> Delete
                            </button>
                          </form>
                        </div>
                </div>
              </div>
              <% }) %>
          </div>
          <% } %>
    </div>

    <!-- Listing Type Modal -->
    <div id="listingTypeModal" class="listing-modal">
      <div class="modal-overlay"></div>
      <div class="modal-container">
        <div class="modal-header">
          <h2 class="modal-title">What would you like to host?</h2>
          <button class="modal-close-btn" id="closeListingModal">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>

        <div class="modal-content">
          <div class="listing-options">
            <!-- Home Option -->
            <a href="/listings/new?type=home" class="listing-option">
              <div class="option-icon">
                <i class="fa-solid fa-house"></i>
              </div>
              <div class="option-info">
                <h3>Home</h3>
                <p>List your entire place, private room, or shared room</p>
              </div>
              <div class="option-arrow">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            </a>

            <!-- Experience Option -->
            <a href="/listings/new?type=experience" class="listing-option">
              <div class="option-icon">
                <i class="fa-solid fa-compass"></i>
              </div>
              <div class="option-info">
                <h3>Experience</h3>
                <p>Share an activity, tour, or class with travelers</p>
              </div>
              <div class="option-arrow">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            </a>

            <!-- Service Option -->
            <a href="/listings/new?type=service" class="listing-option">
              <div class="option-icon">
                <i class="fa-solid fa-bell-concierge"></i>
              </div>
              <div class="option-info">
                <h3>Service</h3>
                <p>Offer a professional service like photography or cooking</p>
              </div>
              <div class="option-arrow">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>

    <style>
      /* ===== HOST LISTINGS STYLES ===== */
      .host-listings-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 24px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        min-height: calc(100vh - 80px);
        background: #fafafa;
      }

      /* Header */
      .host-listings-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 40px;
        padding-bottom: 24px;
        border-bottom: 1px solid #ebebeb;
      }

      .host-listings-header h1 {
        font-size: 42px;
        font-weight: 600;
        color: #222;
        margin: 0 0 8px 0;
        line-height: 1.1;
        letter-spacing: -0.5px;
      }

      .header-subtitle {
        font-size: 16px;
        color: #717171;
        margin: 0;
      }

      .create-listing-btn {
        background: #ff385c;
        color: white;
        border: none;
        padding: 14px 28px;
        border-radius: 40px;
        font-size: 16px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(255, 56, 92, 0.2);
      }

      .create-listing-btn:hover {
        background: #e31c5f;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(255, 56, 92, 0.3);
      }

      .create-listing-btn i {
        font-size: 18px;
      }

      /* Listings Grid */
      .listings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 24px;
      }

      /* Listing Card */
      .listing-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid #ebebeb;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      }

      .listing-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 32px rgba(0, 0, 0, 0.08);
        border-color: #ff385c;
      }

      /* Listing Image */
      .listing-image {
        position: relative;
        height: 200px;
        overflow: hidden;
        background: #f7f7f7;
      }

      .listing-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }

      .listing-card:hover .listing-image img {
        transform: scale(1.08);
      }

      /* Badges */
      .photo-count-badge {
        position: absolute;
        bottom: 16px;
        left: 16px;
        background: rgba(0, 0, 0, 0.8);
        color: white;
        padding: 6px 12px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 6px;
        backdrop-filter: blur(4px);
        z-index: 2;
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .photo-count-badge i {
        font-size: 12px;
      }

      .listing-status {
        position: absolute;
        top: 16px;
        right: 16px;
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.3px;
        z-index: 2;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .listing-status.published {
        background: #00a699;
        color: white;
      }

      .listing-status.draft {
        background: white;
        color: #222;
        border: 1px solid #ddd;
      }

      /* Listing Info */
      .listing-info {
        padding: 20px;
      }

      .listing-info h3 {
        font-size: 18px;
        font-weight: 600;
        color: #222;
        margin: 0 0 8px 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .listing-location {
        font-size: 14px;
        color: #717171;
        margin: 0 0 16px 0;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .listing-location i {
        color: #ff385c;
        font-size: 12px;
      }

      /* Stats */
      .listing-stats {
        display: flex;
        gap: 20px;
        margin-bottom: 16px;
        padding: 12px 0;
        border-top: 1px solid #ebebeb;
        border-bottom: 1px solid #ebebeb;
      }

      .stat-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: #222;
      }

      .stat-item i {
        color: #ff385c;
        font-size: 14px;
        width: 16px;
      }

      .stat-value {
        font-weight: 600;
      }

      /* Last Viewed */
      .last-viewed {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: #717171;
        margin-bottom: 16px;
        padding: 8px 12px;
        background: #f7f7f7;
        border-radius: 8px;
      }

      .last-viewed i {
        color: #ff385c;
        font-size: 12px;
      }

      .last-viewed.never {
        background: #fff0f2;
        color: #ff385c;
      }

      .last-viewed.never i {
        color: #ff385c;
      }

      /* Price */
      .listing-price {
        font-size: 20px;
        font-weight: 600;
        color: #222;
        margin-bottom: 20px;
      }

      .listing-price span {
        font-weight: 400;
        font-size: 14px;
        color: #717171;
        margin-left: 4px;
      }

      /* Actions */
      .listing-actions {
        display: flex;
        gap: 8px;
      }

      .action-btn {
        flex: 1;
        text-align: center;
        padding: 10px 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        text-decoration: none;
        color: #222;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.2s ease;
        background: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        cursor: pointer;
      }

      .action-btn i {
        font-size: 14px;
      }

      .action-btn:hover {
        background: #f7f7f7;
        border-color: #ccc;
      }

      .preview-btn:hover {
        background: #222;
        color: white;
        border-color: #222;
      }

      .edit-btn:hover {
        background: #ff385c;
        color: white;
        border-color: #ff385c;
      }

      .delete-form {
        flex: 1;
      }

      .delete-btn {
        width: 100%;
        border-color: #ff385c;
        color: #ff385c;
      }

      .delete-btn:hover {
        background: #ff385c;
        color: white;
      }

      /* Empty State */
      .empty-state {
        text-align: center;
        max-width: 500px;
        margin: 100px auto;
        padding: 40px;
      }

      .empty-state-icon {
        margin-bottom: 24px;
        color: #222;
        animation: float 3s ease-in-out infinite;
      }

      @keyframes float {

        0%,
        100% {
          transform: translateY(0);
        }

        50% {
          transform: translateY(-10px);
        }
      }

      .empty-state-title {
        font-size: 32px;
        font-weight: 600;
        color: #222;
        line-height: 1.3;
        margin: 0 0 16px 0;
      }

      .empty-state-text {
        font-size: 18px;
        color: #717171;
        line-height: 1.6;
        margin: 0 0 32px 0;
      }

      .complete-listing-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #ff385c;
        color: white;
        font-size: 16px;
        font-weight: 600;
        padding: 16px 32px;
        border-radius: 40px;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(255, 56, 92, 0.2);
      }

      .complete-listing-btn:hover {
        background: #e31c5f;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(255, 56, 92, 0.3);
      }

      /* Modal Styles */
      .listing-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 10000;
        align-items: center;
        justify-content: center;
      }

      .listing-modal.show {
        display: flex;
      }

      .modal-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
      }

      .modal-container {
        position: relative;
        width: 90%;
        max-width: 600px;
        background: white;
        border-radius: 24px;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
        z-index: 10001;
        animation: modalSlideIn 0.3s ease;
      }

      @keyframes modalSlideIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 24px 16px;
        border-bottom: 1px solid #ebebeb;
      }

      .modal-title {
        font-size: 28px;
        font-weight: 600;
        color: #222;
        margin: 0;
        line-height: 1.2;
      }

      .modal-close-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: none;
        background: #f7f7f7;
        color: #222;
        font-size: 20px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
      }

      .modal-close-btn:hover {
        background: #ebebeb;
        transform: rotate(90deg);
      }

      .modal-content {
        padding: 24px;
      }

      .listing-options {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .listing-option {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px;
        border: 2px solid #ebebeb;
        border-radius: 20px;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
      }

      .listing-option:hover {
        border-color: #ff385c;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(255, 56, 92, 0.12);
        background: #fff9f9;
      }

      .listing-option::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: #ff385c;
        transform: scaleY(0);
        transition: transform 0.2s ease;
      }

      .listing-option:hover::before {
        transform: scaleY(1);
      }

      .option-icon {
        width: 60px;
        height: 60px;
        background: #f7f7f7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: #ff385c;
        flex-shrink: 0;
        transition: all 0.2s ease;
      }

      .listing-option:hover .option-icon {
        background: #ff385c;
        color: white;
        transform: scale(1.05);
      }

      .option-info {
        flex: 1;
      }

      .option-info h3 {
        font-size: 20px;
        font-weight: 600;
        color: #222;
        margin: 0 0 4px 0;
      }

      .option-info p {
        font-size: 15px;
        color: #717171;
        margin: 0;
        line-height: 1.5;
      }

      .option-arrow {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #f7f7f7;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #222;
        font-size: 16px;
        transition: all 0.2s ease;
        flex-shrink: 0;
      }

      .listing-option:hover .option-arrow {
        background: #ff385c;
        color: white;
        transform: translateX(4px);
      }

      /* Responsive Design */
      @media (max-width: 1024px) {
        .listings-grid {
          grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        }
      }

      @media (max-width: 768px) {
        .host-listings-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 20px;
        }

        .host-listings-header h1 {
          font-size: 36px;
        }

        .create-listing-btn {
          width: 100%;
          justify-content: center;
        }

        .listings-grid {
          grid-template-columns: 1fr;
        }

        .modal-container {
          width: 95%;
          margin: 20px;
        }

        .modal-title {
          font-size: 24px;
        }

        .listing-option {
          padding: 16px;
          gap: 16px;
        }

        .option-icon {
          width: 50px;
          height: 50px;
          font-size: 24px;
        }
      }

      @media (max-width: 480px) {
        .host-listings-header h1 {
          font-size: 28px;
        }

        .listing-actions {
          flex-direction: column;
        }

        .action-btn {
          width: 100%;
        }

        .listing-stats {
          flex-wrap: wrap;
          gap: 12px;
        }

        .modal-title {
          font-size: 20px;
        }

        .option-info h3 {
          font-size: 18px;
        }

        .option-info p {
          font-size: 13px;
        }
      }

      .analytics-btn {
        background: #00a699;
        color: white;
        border-color: #00a699;
      }

      .analytics-btn:hover {
        background: #00847a;
        color: white;
      }
    </style>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const modal = document.getElementById('listingTypeModal');
        const openModalBtn = document.getElementById('openListingModalBtn');
        const openModalBtnEmpty = document.getElementById('openListingModalBtnEmpty');
        const closeModalBtn = document.getElementById('closeListingModal');
        const modalOverlay = document.querySelector('.modal-overlay');

        // Function to open modal
        function openModal() {
          modal.classList.add('show');
          document.body.style.overflow = 'hidden';
        }

        // Function to close modal
        function closeModal() {
          modal.classList.remove('show');
          document.body.style.overflow = '';
        }

        // Open modal when button is clicked
        if (openModalBtn) {
          openModalBtn.addEventListener('click', openModal);
        }

        if (openModalBtnEmpty) {
          openModalBtnEmpty.addEventListener('click', openModal);
        }

        // Close modal when X is clicked
        if (closeModalBtn) {
          closeModalBtn.addEventListener('click', closeModal);
        }

        // Close modal when overlay is clicked
        if (modalOverlay) {
          modalOverlay.addEventListener('click', closeModal);
        }

        // Close modal when Escape key is pressed
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.classList.contains('show')) {
            closeModal();
          }
        });

        // Prevent modal from closing when clicking inside the modal container
        const modalContainer = document.querySelector('.modal-container');
        if (modalContainer) {
          modalContainer.addEventListener('click', function (e) {
            e.stopPropagation();
          });
        }

        // Add touch support for mobile
        if ('ontouchstart' in window) {
          const options = document.querySelectorAll('.listing-option');
          options.forEach(option => {
            option.addEventListener('touchstart', function () {
              this.style.transform = 'scale(0.98)';
            });
            option.addEventListener('touchend', function () {
              this.style.transform = '';
            });
          });
        }
      });
    </script>