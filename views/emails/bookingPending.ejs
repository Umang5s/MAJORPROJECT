<!-- views/emails/bookingPending.ejs -->
<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #ff385c; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background: #f9f9f9; }
    .button { display: inline-block; padding: 10px 20px; background: #ff385c; color: white; text-decoration: none; border-radius: 5px; }
    .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
    .warning { background: #fff3cd; border: 1px solid #ffeeba; color: #856404; padding: 10px; border-radius: 5px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Booking Pending ⏳</h1>
    </div>
    <div class="content">
      <h2>Hi <%= userName %>,</h2>
      <p>Your booking for <strong><%= listingTitle %></strong> is currently pending confirmation.</p>
      
      <div class="warning">
        <p><strong>⏰ This booking will expire in <%= expiresIn %> if not confirmed.</strong></p>
      </div>
      
      <h3>Booking Details:</h3>
      <ul>
        <li><strong>Check-in:</strong> <%= from %></li>
        <li><strong>Check-out:</strong> <%= to %></li>
        <li><strong>Rooms:</strong> <%= roomsBooked %></li>
        <li><strong>Total:</strong> ₹<%= totalPrice %></li>
        <li><strong>Booking ID:</strong> <%= bookingId %></li>
      </ul>
      
      <p>Your booking will be automatically confirmed if rooms become available (if someone cancels or their booking expires). You'll receive another email once confirmed.</p>
      
      <p>Need to cancel? <a href="<%= siteUrl %>/bookings/my">View your bookings</a></p>
    </div>
    <div class="footer">
      <p>© 2024 Your Company. All rights reserved.</p>
    </div>
  </div>
</body>
</html>