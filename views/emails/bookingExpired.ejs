<!-- views/emails/bookingExpired.ejs -->
<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #dc3545; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; background: #f9f9f9; }
    .button { display: inline-block; padding: 10px 20px; background: #ff385c; color: white; text-decoration: none; border-radius: 5px; }
    .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Booking Expired ⏰</h1>
    </div>
    <div class="content">
      <h2>Hi <%= userName %>,</h2>
      <p>Your pending booking for <strong><%= listingTitle %></strong> has expired.</p>
      
      <h3>Booking Details:</h3>
      <ul>
        <li><strong>Check-in:</strong> <%= from %></li>
        <li><strong>Check-out:</strong> <%= to %></li>
        <li><strong>Booking ID:</strong> <%= bookingId %></li>
      </ul>
      
      <p>This booking was not confirmed within the 15-minute window. You can try booking again if dates are still available.</p>
      
      <a href="<%= siteUrl %>/listings/<%= bookingId %>" class="button">Book Again</a>
      
      <p style="margin-top: 20px;">Need help? <a href="<%= siteUrl %>/help">Contact support</a></p>
    </div>
    <div class="footer">
      <p>© 2024 Your Company. All rights reserved.</p>
    </div>
  </div>
</body>
</html>