<%- layout("/layout/boilerplate") %>
<link rel="stylesheet" href="/css/show.css" />

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="listing-show-container">
  <!-- Header with title and actions -->
  <div class="listing-header">
    <div class="container">
      <h1 class="listing-title"><%= listing.title %></h1>
      <div class="listing-location">
        <i class="fa-regular fa-location-dot"></i>
        <%= listing.location || listing.city || 'Location not specified' %>, <%= listing.country || 'India' %>
      </div>
      <div class="header-actions">
        <button class="action-btn"><i class="fa-regular fa-share-nodes"></i> Share</button>
        <button class="action-btn"><i class="fa-regular fa-heart"></i> Save</button>
      </div>
    </div>
  </div>

  <!-- Photo Gallery -->
<div class="photo-gallery container">
  <% if (listing.images && listing.images.length > 0) { %>
    <div class="gallery-grid <%= listing.images.length === 1 ? 'single' : (listing.images.length === 2 ? 'two' : 'multi') %>">
      <% 
        // Show first 5 photos in grid
        const displayImages = listing.images.slice(0, 5);
        displayImages.forEach((img, index) => { 
      %>
        <div class="gallery-item" data-index="<%= index %>">
          <img src="<%= img.url %>" alt="<%= listing.title %> - photo <%= index+1 %>">
          
          <!-- Show "Show all photos" button on the 4th image if there are more than 5 photos -->
          <% if (listing.images.length > 5 && index === 4) { %>
            <div class="gallery-overlay-corner">
              <button class="show-all-photos-corner" id="showAllPhotosBtn">
                <i class="fa-regular fa-grid-2"></i> Show all <%= listing.images.length %> photos
              </button>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="no-photo-placeholder">
      <i class="fa-regular fa-image"></i> No photos yet
    </div>
  <% } %>
</div>

  <!-- Main content area (2 columns on large screens) -->
  <div class="container main-content">
    <div class="content-left">
      <!-- Host info card -->
      <div class="host-card">
        <div class="host-avatar">
          <img src="<%= listing.owner?.avatar?.url || '/images/default-avatar.png' %>" alt="<%= listing.owner?.username %>">
        </div>
        <div class="host-details">
          <div class="host-name">
            Hosted by <%= listing.owner?.username || 'Unknown' %>
            <% if (listing.owner?.isSuperhost) { %>
              <span class="superhost-badge"><i class="fa-regular fa-medal"></i> Superhost</span>
            <% } %>
          </div>
          <div class="host-stats">
            <span><%= listing.owner?.hostingYears || '8' %> years hosting</span>
            <span>•</span>
            <span><i class="fa-regular fa-message"></i> Response rate 100%</span>
          </div>
        </div>
      </div>

      <!-- Key details: guests, bedrooms, beds, bathrooms -->
      <div class="key-details">
        <div class="detail-item">
          <i class="fa-regular fa-user-group"></i>
          <span><%= listing.guests || 2 %> guests</span>
        </div>
        <div class="detail-item">
          <i class="fa-regular fa-bed"></i>
          <span><%= listing.bedrooms || 1 %> bedroom</span>
        </div>
        <div class="detail-item">
          <i class="fa-regular fa-bed-front"></i>
          <span><%= listing.beds || 1 %> bed</span>
        </div>
        <div class="detail-item">
          <i class="fa-regular fa-bath"></i>
          <span><%= listing.bathrooms || 1 %> bathroom</span>
        </div>
      </div>

      <!-- Property type badge -->
      <div class="property-badge">
        <%= listing.propertyType ? listing.propertyType.charAt(0).toUpperCase() + listing.propertyType.slice(1) : 'Entire place' %> • 
        <%= listing.guestAccess === 'entire' ? 'Entire home' : (listing.guestAccess === 'room' ? 'Private room' : 'Shared room') %>
      </div>

      <!-- Description -->
      <div class="description-section">
        <p><%= listing.description %></p>
      </div>

      <!-- Where you'll sleep -->
      <% if (listing.bedrooms > 0) { %>
        <div class="sleep-section">
          <h2>Where you'll sleep</h2>
          <div class="sleep-grid">
            <% for (let i = 0; i < listing.bedrooms; i++) { %>
              <div class="sleep-card">
                <i class="fa-regular fa-bed"></i>
                <div>Bedroom <%= i+1 %></div>
                <div class="bed-type"><%= listing.beds && listing.beds >= i+1 ? '1 double bed' : '1 bed' %></div>
              </div>
            <% } %>
          </div>
        </div>
      <% } %>

      <!-- What this place offers (amenities) -->
      <% if (listing.amenities && listing.amenities.length > 0) { %>
        <div class="amenities-section">
          <h2>What this place offers</h2>
          <div class="amenities-grid">
            <% listing.amenities.forEach(amenity => { %>
              <div class="amenity-item">
                <i class="fa-regular fa-circle-check"></i>
                <span><%= amenity %></span>
              </div>
            <% }) %>
          </div>
          <% if (listing.amenities.length > 10) { %>
            <button class="show-all-amenities">Show all <%= listing.amenities.length %> amenities</button>
          <% } %>
        </div>
      <% } %>

      <!-- Safety items -->
      <% if (listing.safetyItems && listing.safetyItems.length > 0) { %>
        <div class="safety-section">
          <h2>Safety features</h2>
          <div class="safety-items">
            <% listing.safetyItems.forEach(item => { %>
              <div class="safety-item">
                <i class="fa-regular fa-shield-check"></i>
                <span><%= item %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Location map -->
      <div class="map-section">
        <h2>Where you'll be</h2>
        <div id="showMap" class="show-map"></div>
        <div class="location-address"><%= listing.location %>, <%= listing.country %></div>
      </div>

      <!-- ========== REVIEWS SECTION - AIRBNB STYLE ========== -->
<div class="reviews-section">
  <!-- Reviews Header -->
  <div class="reviews-header">
    <div class="reviews-title">
      <h2>
        <span class="rating-star">★</span> 
        <%= listing.avgRating ? listing.avgRating.toFixed(1) : 'New' %> · 
        <%= listing.reviewCount || 0 %> reviews
      </h2>
    </div>
    <button class="how-reviews-work-btn" id="howReviewsWorkBtn">
      <i class="fa-regular fa-circle-question"></i> How reviews work
    </button>
  </div>

  <!-- Guest Favorite Badge (shows when rating is 5.0) -->
  <% if (listing.reviewCount >= 5 && listing.avgRating >= 4.8) { %>
  <div class="guest-favorite-badge">
    <div class="favorite-icon">
      <i class="fa-solid fa-medal"></i>
    </div>
    <div class="favorite-text">
      <strong>Guest favourite</strong>
      <span>This home is in the top 10% of eligible listings based on ratings, reviews and reliability</span>
    </div>
    <a href="#" class="how-reviews-link">How reviews work</a>
  </div>
  <% } %>

  <!-- Big Rating Display -->
  <div class="big-rating-display">
    <div class="rating-number-large">
      <%= listing.avgRating ? listing.avgRating.toFixed(1) : '5.0' %>
    </div>
    <div class="rating-stars-large">
      <% for (let i = 1; i <= 5; i++) { %>
        <i class="<%= i <= Math.round(listing.avgRating || 5) ? 'fa-solid fa-star' : 'fa-regular fa-star' %>"></i>
      <% } %>
    </div>
  </div>

  <!-- Category Ratings Grid -->
  <div class="category-ratings-grid">
    <div class="category-item">
      <span class="category-name">Overall rating</span>
      <span class="category-value"><%= listing.avgRating ? listing.avgRating.toFixed(1) : '5.0' %></span>
    </div>
    <div class="category-item">
      <span class="category-name">Cleanliness</span>
      <span class="category-value"><%= listing.avgCleanliness ? listing.avgCleanliness.toFixed(1) : '5.0' %></span>
    </div>
    <div class="category-item">
      <span class="category-name">Accuracy</span>
      <span class="category-value"><%= listing.avgAccuracy ? listing.avgAccuracy.toFixed(1) : '5.0' %></span>
    </div>
    <div class="category-item">
      <span class="category-name">Check-in</span>
      <span class="category-value"><%= listing.avgCheckIn ? listing.avgCheckIn.toFixed(1) : '5.0' %></span>
    </div>
    <div class="category-item">
      <span class="category-name">Communication</span>
      <span class="category-value"><%= listing.avgCommunication ? listing.avgCommunication.toFixed(1) : '5.0' %></span>
    </div>
    <div class="category-item">
      <span class="category-name">Location</span>
      <span class="category-value"><%= listing.avgLocation ? listing.avgLocation.toFixed(1) : '5.0' %></span>
    </div>
    <div class="category-item">
      <span class="category-name">Value</span>
      <span class="category-value"><%= listing.avgValue ? listing.avgValue.toFixed(1) : '5.0' %></span>
    </div>
  </div>

  <!-- Category Tags (large pills) - HORIZONTAL SCROLLABLE -->
  <div class="category-tags-scroll-container">
    <div class="category-tags-scroll">
      <span class="category-tag-large" data-category="hospitality">Hospitality 4</span>
      <span class="category-tag-large" data-category="cleanliness">Cleanliness 3</span>
      <span class="category-tag-large" data-category="accuracy">Accuracy 2</span>
      <span class="category-tag-large" data-category="comfort">Comfort 2</span>
      <span class="category-tag-large" data-category="location">Location 2</span>
      <span class="category-tag-large" data-category="value">Value 4</span>
      <span class="category-tag-large" data-category="communication">Communication 4</span>
      <span class="category-tag-large" data-category="checkIn">Check-in 4</span>
    </div>
  </div>

  <!-- Filter and Sort Bar - HORIZONTAL SCROLLABLE FILTERS -->
  <div class="filter-sort-wrapper">
    <div class="reviews-filter-scroll">
      <div class="filter-buttons">
        <button class="filter-btn active" data-filter="all">All reviews</button>
        <button class="filter-btn" data-filter="cleanliness">Cleanliness</button>
        <button class="filter-btn" data-filter="accuracy">Accuracy</button>
        <button class="filter-btn" data-filter="communication">Communication</button>
        <button class="filter-btn" data-filter="location">Location</button>
        <button class="filter-btn" data-filter="checkIn">Check-in</button>
        <button class="filter-btn" data-filter="value">Value</button>
        <button class="filter-btn" data-filter="hospitality">Hospitality</button>
        <button class="filter-btn" data-filter="comfort">Comfort</button>
      </div>
    </div>
    <div class="sort-dropdown">
      <select id="sortReviews" class="sort-select">
        <option value="newest">Newest first</option>
        <option value="oldest">Oldest first</option>
        <option value="highest">Highest rated</option>
        <option value="lowest">Lowest rated</option>
      </select>
    </div>
  </div>

  <!-- Category Modal with Category Options (for category tags) -->
  <div id="categoryModal" class="category-modal">
    <div class="category-modal-content">
      <div class="category-modal-header">
        <h3 id="modalCategoryTitle">Hospitality · <span id="reviewCount">4</span> reviews</h3>
        <span class="close-modal">&times;</span>
      </div>
      
      <!-- Category Options Bar inside Modal -->
      <div class="modal-category-options">
        <span class="modal-category-option active" data-modal-category="hospitality">Hospitality</span>
        <span class="modal-category-option" data-modal-category="cleanliness">Cleanliness</span>
        <span class="modal-category-option" data-modal-category="accuracy">Accuracy</span>
        <span class="modal-category-option" data-modal-category="communication">Communication</span>
        <span class="modal-category-option" data-modal-category="location">Location</span>
        <span class="modal-category-option" data-modal-category="checkIn">Check-in</span>
        <span class="modal-category-option" data-modal-category="value">Value</span>
        <span class="modal-category-option" data-modal-category="comfort">Comfort</span>
      </div>
      
      <div class="category-modal-body" id="modalReviewsList">
        <!-- Reviews will be loaded here -->
      </div>
    </div>
  </div>

  <!-- Review Detail Modal (for individual "Show more") - WITH TOP RATING SECTION -->
<div id="reviewDetailModal" class="review-detail-modal">
  <div class="review-detail-content">
    <div class="review-detail-header">
      <h3 id="reviewDetailModalTitle">Reviews</h3>
      <span class="close-modal">&times;</span>
    </div>
    
    <!-- TOP RATING SECTION - Like the image -->
    <div class="modal-top-rating">
      <div class="modal-big-rating">
        <span class="modal-rating-number"><%= listing.avgRating ? listing.avgRating.toFixed(1) : '4.5' %></span>
        <div class="modal-rating-stars">
          <% for (let i = 1; i <= 5; i++) { %>
            <i class="<%= i <= Math.round(listing.avgRating || 4.5) ? 'fa-solid fa-star' : 'fa-regular fa-star' %>"></i>
          <% } %>
        </div>
      </div>
      
      <!-- Category Breakdown Grid (like in the image) -->
      <div class="modal-category-breakdown">
        <div class="breakdown-row">
          <span class="breakdown-label">Overall</span>
          <div class="breakdown-bar-container">
            <div class="breakdown-bar" style="width: <%= (listing.avgRating || 4.5) * 20 %>%"></div>
          </div>
          <span class="breakdown-value"><%= listing.avgRating ? listing.avgRating.toFixed(1) : '4.5' %></span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">Cleanliness</span>
          <div class="breakdown-bar-container">
            <div class="breakdown-bar" style="width: <%= (listing.avgCleanliness || 5) * 20 %>%"></div>
          </div>
          <span class="breakdown-value"><%= listing.avgCleanliness ? listing.avgCleanliness.toFixed(1) : '5.0' %></span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">Accuracy</span>
          <div class="breakdown-bar-container">
            <div class="breakdown-bar" style="width: <%= (listing.avgAccuracy || 4.5) * 20 %>%"></div>
          </div>
          <span class="breakdown-value"><%= listing.avgAccuracy ? listing.avgAccuracy.toFixed(1) : '4.5' %></span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">Check-in</span>
          <div class="breakdown-bar-container">
            <div class="breakdown-bar" style="width: <%= (listing.avgCheckIn || 4) * 20 %>%"></div>
          </div>
          <span class="breakdown-value"><%= listing.avgCheckIn ? listing.avgCheckIn.toFixed(1) : '4.0' %></span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">Communication</span>
          <div class="breakdown-bar-container">
            <div class="breakdown-bar" style="width: <%= (listing.avgCommunication || 4) * 20 %>%"></div>
          </div>
          <span class="breakdown-value"><%= listing.avgCommunication ? listing.avgCommunication.toFixed(1) : '4.0' %></span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">Location</span>
          <div class="breakdown-bar-container">
            <div class="breakdown-bar" style="width: <%= (listing.avgLocation || 5) * 20 %>%"></div>
          </div>
          <span class="breakdown-value"><%= listing.avgLocation ? listing.avgLocation.toFixed(1) : '5.0' %></span>
        </div>
        <div class="breakdown-row">
          <span class="breakdown-label">Value</span>
          <div class="breakdown-bar-container">
            <div class="breakdown-bar" style="width: <%= (listing.avgValue || 4.5) * 20 %>%"></div>
          </div>
          <span class="breakdown-value"><%= listing.avgValue ? listing.avgValue.toFixed(1) : '4.5' %></span>
        </div>
      </div>
    </div>
    
    <!-- Category Filter Pills inside Modal -->
    <div class="modal-filter-pills">
      <span class="filter-pill active" data-filter="all">All</span>
      <span class="filter-pill" data-filter="hospitality">Hospitality</span>
      <span class="filter-pill" data-filter="cleanliness">Cleanliness</span>
      <span class="filter-pill" data-filter="accuracy">Accuracy</span>
      <span class="filter-pill" data-filter="communication">Communication</span>
      <span class="filter-pill" data-filter="location">Location</span>
      <span class="filter-pill" data-filter="checkIn">Check-in</span>
      <span class="filter-pill" data-filter="value">Value</span>
      <span class="filter-pill" data-filter="comfort">Comfort</span>
    </div>
    
    <div class="review-detail-body" id="reviewDetailBody">
      <!-- Reviews will be loaded here -->
    </div>
  </div>
</div>

  <!-- Reviews List -->
  <div class="reviews-list" id="reviewsList">
    <% 
      const guestReviews = listing.reviews?.filter(r => r.reviewType === 'guest-to-host') || [];
      const initialReviews = guestReviews.slice(0, 5);
      const hasMoreReviews = guestReviews.length > 5;
    %>
    <% if (guestReviews.length > 0) { %>
      <% initialReviews.forEach(review => { 
        const yearsOnAirbnb = Math.floor(Math.random() * 5) + 1;
        const firstLetter = review.author?.username ? review.author.username[0].toUpperCase() : 'G';
        
        // Helper function to get rating
        const getRating = (cat) => review[cat]?.rating || 0;
      %>
      <div class="review-card" 
           data-id="<%= review._id %>"
           data-cleanliness="<%= getRating('cleanliness') %>"
           data-accuracy="<%= getRating('accuracy') %>"
           data-communication="<%= getRating('communication') %>"
           data-location="<%= getRating('location') %>"
           data-checkin="<%= getRating('checkIn') %>"
           data-value="<%= getRating('value') %>"
           data-hospitality="<%= review.hospitality?.rating || 0 %>"
           data-comfort="<%= review.comfort?.rating || 0 %>"
           data-date="<%= new Date(review.createdAt).getTime() %>"
           data-rating="<%= review.overallRating || 0 %>"
           data-review='<%= JSON.stringify(review).replace(/'/g, "&apos;") %>'>
        
        <!-- Review Header -->
        <div class="review-header">
          <div class="reviewer-avatar">
            <% if (review.author?.avatar?.url) { %>
              <img src="<%= review.author.avatar.url %>" alt="<%= review.author?.username %>">
            <% } else { %>
              <div class="avatar-placeholder"><%= firstLetter %></div>
            <% } %>
          </div>
          <div class="reviewer-info">
            <div class="reviewer-name"><%= review.author?.username || 'Anonymous' %></div>
            <div class="reviewer-meta">
              <span class="review-years"><i class="fa-regular fa-clock"></i> <%= yearsOnAirbnb %> years on Airbnb</span>
              <span class="review-date">· <%= new Date(review.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
            </div>
          </div>
        </div>

        <!-- Rating Stars -->
        <div class="review-rating-stars">
          <% for (let i = 1; i <= 5; i++) { %>
            <i class="<%= i <= Math.round(review.overallRating || 0) ? 'fa-solid fa-star' : 'fa-regular fa-star' %>"></i>
          <% } %>
        </div>

        <!-- Review Comment (truncated) -->
        <div class="review-comment-wrapper">
          <% 
            let commentText = '';
            let commentLength = 0;
            
            if (review.overallComment && review.overallComment.trim().length > 0) {
              commentText = review.overallComment;
              commentLength = review.overallComment.length;
            } else if (review.comment && review.comment.trim().length > 0) {
              commentText = review.comment;
              commentLength = review.comment.length;
            } else {
              commentText = 'No written review provided';
            }
          %>
          <p class="review-comment"><%= commentLength > 150 ? commentText.substring(0, 150) + '...' : commentText %></p>
        </div>

        <!-- Show more link (opens individual review modal) -->
        <div class="review-show-more">
          <a href="#" class="show-more-link" data-review-id="<%= review._id %>">Show more <i class="fa-regular fa-arrow-right"></i></a>
        </div>

        <!-- Host Reply (if exists) -->
        <% if (review.hostReply && review.hostReply.text) { %>
        <div class="host-reply">
          <div class="host-reply-header">
            <span class="host-reply-name">Response from <%= listing.owner?.username || 'Host' %></span>
            <span class="host-reply-date"><%= new Date(review.hostReply.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
          </div>
          <p class="host-reply-text"><%= review.hostReply.text %></p>
        </div>
        <% } %>
      </div>
      <% }) %>

      <!-- Show more reviews button -->
      <% if (hasMoreReviews) { %>
      <div class="show-more-reviews">
        <button class="show-all-reviews-btn" id="showAllReviewsBtn">
          Show all <%= guestReviews.length %> reviews
        </button>
      </div>
      <% } %>

    <% } else { %>
      <div class="no-reviews">
        <i class="fa-regular fa-star"></i>
        <p>No reviews yet. Be the first to leave a review!</p>
      </div>
    <% } %>
  </div>

  <!-- How Reviews Work Modal -->
  <div id="howReviewsModal" class="how-reviews-modal">
    <div class="modal-content">
      <span class="close-modal">&times;</span>
      <h2>How reviews work</h2>
      
      <div class="modal-body">
        <p>Reviews from past guests help our community learn more about each home. By default, reviews are sorted by relevance. Relevance is based on recency, length and information that you provide to us, such as your booking search, your country and your language preferences.</p>
        <p>Only the guest who made the reservation can leave a review, and Airbnb only moderates reviews flagged for not following our policies.</p>
        <p>To be eligible for a percentile ranking or guest favourite label, listings need at least 5 reviews in the last 4 years. Criteria are subject to change.</p>
        <div class="help-link">
          <a href="#">Learn more in our Help Centre <i class="fa-regular fa-arrow-right"></i></a>
        </div>
      </div>

      <!-- Rating Distribution -->
      <div class="rating-distribution">
        <h3>Rating distribution</h3>
        <% 
          const distribution = {5:0,4:0,3:0,2:0,1:0};
          if (listing.reviews) {
            listing.reviews.forEach(r => {
              if (r.isPublished && r.overallRating) {
                distribution[Math.floor(r.overallRating)]++;
              }
            });
          }
          const totalReviews = listing.reviewCount || 0;
        %>
        <% for (let stars = 5; stars >= 1; stars--) { %>
        <div class="distribution-row">
          <span class="star-label"><%= stars %> stars</span>
          <div class="progress-bar-container">
            <div class="progress-bar" style="width: <%= totalReviews > 0 ? (distribution[stars] / totalReviews * 100) : 0 %>%;"></div>
          </div>
          <span class="star-count"><%= distribution[stars] %></span>
        </div>
        <% } %>
      </div>

      <div class="modal-footer">
        <span class="total-reviews"><%= totalReviews %> reviews</span>
        <span class="avg-rating">★ <%= listing.avgRating ? listing.avgRating.toFixed(2) : '0.00' %></span>
      </div>
    </div>
  </div>
</div>
    </div>

    <!-- Right column: Booking card -->
    <div class="content-right">
      <div class="booking-card">
        <div class="price-info">
          <span class="price">₹<%= listing.price?.toLocaleString('en-IN') %></span> <span class="night">night</span>
        </div>
        <div class="rating-badge">
          ★ <%= listing.avgRating ? listing.avgRating.toFixed(1) : 'New' %> · <%= listing.reviewCount || 0 %> reviews
        </div>

        <form action="/bookings/start/<%= listing._id %>" method="POST" id="bookingForm">
          <!-- Date Picker -->
          <div class="date-picker">
            <div class="check-in" id="checkInContainer">
              <label>CHECK-IN</label>
              <input type="text" id="checkInDisplay" placeholder="Add date" readonly>
              <input type="hidden" name="checkIn" id="bookingCheckIn">
            </div>
            <div class="check-out" id="checkOutContainer">
              <label>CHECK-OUT</label>
              <input type="text" id="checkOutDisplay" placeholder="Add date" readonly>
              <input type="hidden" name="checkOut" id="bookingCheckOut">
            </div>
          </div>

          <!-- Rooms Selector -->
          <div class="rooms-selector-container">
            <input type="hidden" id="totalRoomsData" value="<%= listing.totalRooms || listing.bedrooms || 1 %>">
            <label>ROOMS</label>
            <div class="rooms-dropdown">
              <div class="rooms-summary" id="roomsSummary">
                <span id="roomsSummaryText">1 room</span>
                <i class="fa-solid fa-chevron-down"></i>
              </div>
              <div class="rooms-dropdown-content" id="roomsDropdown">
                <div class="rooms-row">
                  <div>
                    <div class="rooms-label">Number of rooms</div>
                    <div class="rooms-available" id="roomsAvailableText">Available: <%= listing.totalRooms || listing.bedrooms || 1 %></div>
                  </div>
                  <div class="rooms-counter">
                    <button type="button" class="counter-btn rooms-minus" id="roomsMinusBtn" data-category="rooms">−</button>
                    <span class="counter-value" id="roomsCount">1</span>
                    <button type="button" class="counter-btn rooms-plus" id="roomsPlusBtn" data-category="rooms">+</button>
                  </div>
                </div>
                <div class="rooms-max-note" id="roomsMaxNote">
                  Maximum <%= listing.totalRooms || listing.bedrooms || 1 %> rooms available
                </div>
              </div>
            </div>
            <input type="hidden" name="roomsBooked" id="roomsTotal" value="1">
          </div>

          <!-- Guest Selector -->
          <div class="guest-selector-container">
            <input type="hidden" id="maxGuestsData" value="<%= listing.guests || 2 %>">
            <label>GUESTS</label>
            <div class="guest-dropdown">
              <div class="guest-summary" id="guestSummary">
                <span id="guestSummaryText">1 guest</span>
                <i class="fa-solid fa-chevron-down"></i>
              </div>
              <div class="guest-dropdown-content" id="guestDropdown">
                <!-- Adults -->
                <div class="guest-row">
                  <div>
                    <div class="guest-label">Adults</div>
                    <div class="guest-age">Age 13+</div>
                  </div>
                  <div class="guest-counter">
                    <button type="button" class="counter-btn minus" data-category="adults">−</button>
                    <span class="counter-value" id="adultsCount">1</span>
                    <button type="button" class="counter-btn plus" data-category="adults">+</button>
                  </div>
                </div>
                <!-- Children -->
                <div class="guest-row">
                  <div>
                    <div class="guest-label">Children</div>
                    <div class="guest-age">Ages 2–12</div>
                  </div>
                  <div class="guest-counter">
                    <button type="button" class="counter-btn minus" data-category="children">−</button>
                    <span class="counter-value" id="childrenCount">0</span>
                    <button type="button" class="counter-btn plus" data-category="children">+</button>
                  </div>
                </div>
                <!-- Infants -->
                <div class="guest-row">
                  <div>
                    <div class="guest-label">Infants</div>
                    <div class="guest-age">Under 2</div>
                  </div>
                  <div class="guest-counter">
                    <button type="button" class="counter-btn minus" data-category="infants">−</button>
                    <span class="counter-value" id="infantsCount">0</span>
                    <button type="button" class="counter-btn plus" data-category="infants">+</button>
                  </div>
                </div>
                <!-- Pets -->
                <div class="guest-row">
                  <div>
                    <div class="guest-label">Pets</div>
                    <div class="guest-age">Bringing a service animal?</div>
                  </div>
                  <div class="guest-counter">
                    <button type="button" class="counter-btn minus" data-category="pets">−</button>
                    <span class="counter-value" id="petsCount">0</span>
                    <button type="button" class="counter-btn plus" data-category="pets">+</button>
                  </div>
                </div>
                <div class="guest-max-note">
                  This place has a maximum of <%= listing.guests %> guests, not including infants and pets.
                </div>
              </div>
            </div>
            <input type="hidden" name="guests" id="guestsTotal" value="1">
          </div>

          <button type="submit" class="reserve-btn">Reserve</button>
          <p class="no-charge">You won't be charged yet</p>
        </form>

        <!-- Price breakdown -->
        <div class="price-breakdown">
          <div class="price-row">
            <span>₹<%= listing.price %> x <span id="nightsCountDisplay">2</span> nights x <span id="roomsCountDisplay">1</span> room</span>
            <span id="totalNightsPrice">₹<%= listing.price * 2 %></span>
          </div>
          <div class="price-row">
            <span>Service fee</span>
            <span id="serviceFee">₹<%= Math.round(listing.price * 2 * 0.14) %></span>
          </div>
          <div class="price-row total">
            <span>Total before taxes</span>
            <span id="totalPrice">₹<%= Math.round(listing.price * 2 * 1.14) %></span>
          </div>
        </div>

        <div class="report">
          <a href="#">Report this listing</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Things to know section -->
  <div class="things-to-know container">
    <h2>Things to know</h2>
    <div class="info-grid">
      <div class="info-col">
        <h3>Cancellation policy</h3>
        <p>Free cancellation before 24 hours. Cancel before check-in on <script>document.write(new Date().toLocaleDateString())</script> for a partial refund.</p>
      </div>
      <div class="info-col">
        <h3>House rules</h3>
        <p>Check-in after 1:00 pm<br>Checkout before 10:00 am<br>Maximum <%= listing.guests %> guests</p>
      </div>
      <div class="info-col">
        <h3>Safety & property</h3>
        <p>
          <% if (listing.safetyItems && listing.safetyItems.includes('exteriorCamera')) { %>
            Exterior security cameras on property<br>
          <% } %>
          <% if (listing.safetyItems && listing.safetyItems.includes('smokeAlarm')) { %>
            Smoke alarm<br>
          <% } %>
          Carbon monoxide alarm
        </p>
      </div>
    </div>
  </div>

  <!-- Host details section -->
  <div class="host-details-section container">
    <h2>Meet your host</h2>
    <div class="host-profile">
      <div class="host-avatar-large">
        <img src="<%= listing.owner?.avatar?.url || '/images/default-avatar.png' %>" alt="">
      </div>
      <div class="host-bio">
        <div class="host-name-large"><%= listing.owner?.username %></div>
        <div class="host-title">Superhost · 8 years hosting</div>
        <p class="host-description">
          <%= listing.owner?.bio || 'I\'m a professional host managing listings in Udaipur. I love helping guests explore the city.' %>
        </p>
        <div class="host-stats">
          <div class="stat">
            <span>Response rate: 100%</span>
          </div>
          <div class="stat">
            <span>Response time: within an hour</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- All photos modal - Updated to show all photos in a grid -->
  <div id="photosModal" class="modal">
    <div class="modal-content">
      <span class="close">&times;</span>
      <h3 class="modal-title">All photos (<%= listing.images?.length || 0 %>)</h3>
      <div class="modal-gallery"></div>
    </div>
  </div>
</div>

<!-- Include flatpickr for date picker -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<!-- Custom JS -->
<script src="/js/show.js"></script>